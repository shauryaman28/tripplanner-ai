# =============================================================
# AI Trip Planner — Environment Variables
# Copy this file to .env and fill in your values.
# ⚠️  Never commit .env to git — it's in .gitignore
# =============================================================

# ── Database (Phase 1 — local Docker) ────────────────────────
POSTGRES_USER=tripplanner
POSTGRES_PASSWORD=tripplanner_secret
POSTGRES_DB=tripplanner_db
DATABASE_URL=postgresql://tripplanner:tripplanner_secret@localhost:5432/tripplanner_db

# ── Redis (Phase 1 — local Docker) ───────────────────────────
REDIS_URL=redis://localhost:6379

# ── FastAPI (Phase 5) ─────────────────────────────────────────
APP_ENV=development
APP_PORT=8000

# JWT — generate secret with: openssl rand -hex 32
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── LLM APIs ──────────────────────────────────────────────────

# Phase 6+ : Gemini Flash — FlightAgent, HotelAgent, ActivitiesAgent
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Phase 12+ : Claude Haiku — Itinerary Builder
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Flight API (Phase 3) ───────────────────────────────────────
# Amadeus sandbox — free at: https://developers.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# ── Hotel API (Phase 3) ────────────────────────────────────────
# Pick ONE option. See Phase 3 notes in the roadmap.

# Option A — Amadeus Hotel Search (recommended, same SDK as flights)
AMADEUS_HOTEL_ENABLED=true

# Option B — RapidAPI hotel aggregator (uncomment if chosen)
# RAPIDAPI_KEY=
# RAPIDAPI_HOST=hotels-com-provider.p.rapidapi.com

# ── Activities / Places API (Phase 3) ─────────────────────────
# Google Maps Places API
# Enable at: https://console.cloud.google.com → APIs & Services
GOOGLE_MAPS_API_KEY=

# ── Weather API (Phase 3) ─────────────────────────────────────
# OpenWeatherMap free tier — sign up at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ── Embeddings (Phase 14) ─────────────────────────────────────
# OpenAI text-embedding-3-small
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Observability (Phase 26) ──────────────────────────────────
# LangSmith tracing — sign up at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=tripplanner-ai

# Sentry error tracking (Phase 27) — sign up at: https://sentry.io
SENTRY_DSN=

# ── Production Infrastructure (Phase 27) ──────────────────────
# Neon — managed Postgres (replaces local Docker)
# Sign up at: https://neon.tech
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/tripplanner_db?sslmode=require

# Upstash — managed Redis (replaces local Docker)
# Sign up at: https://upstash.com
# REDIS_URL=rediss://default:xxx@xxx.upstash.io:6380

# Railway backend deploy URL (set after Phase 27 deploy)
# BACKEND_URL=https://tripplanner-api.up.railway.app

# Vercel frontend deploy URL (set after Phase 27 deploy)
# FRONTEND_URL=https://tripplanner-ai.vercel.app
